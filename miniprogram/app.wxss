/* 通用样式重置 */
page {
  font-size: 28rpx;
  color: #333;
  background-color: #f5f5f5;
  height: 100%;
}

/* 通用容器 */
.container {
  padding: 20rpx;
  box-sizing: border-box;
}

/* 按钮样式 */
.btn {
  background-color: #4CAF50;
  color: #fff;
  border-radius: 8rpx;
  text-align: center;
  padding: 20rpx;
  margin: 20rpx 0;
  font-size: 32rpx;
}

.btn-disabled {
  background-color: #ccc;
  color: #999;
}

/* 输入框样式 */
.input {
  border: 1px solid #eee;
  border-radius: 8rpx;
  padding: 20rpx;
  margin: 10rpx 0;
  background-color: #fff;
  font-size: 28rpx;
}

/* 卡片样式 */
.card {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

/* 空数据提示 */
.empty {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* 加载中样式 */
.loading {
  text-align: center;
  padding: 50rpx 0;
  color: #666;
  font-size: 28rpx;
}

/* 标题样式 */
.title {
  font-size: 36rpx;
  font-weight: bold;
  margin: 20rpx 0;
  color: #333;
}

/* 副标题样式 */
.subtitle {
  font-size: 28rpx;
  color: #666;
  margin: 10rpx 0;
}

:root {
  --primary-color: #07c160;
  --primary-dark: #06ad56;
  --secondary-color: #ff9500;
  --danger-color: #fa5151;
  --warning-color: #ffc300;
  --info-color: #10aeff;
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-tertiary: #999999;
  --bg-color: #f5f5f5;
  --border-color: #e5e5e5;
}

/* 页面基础样式 */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', 'Fira Sans', 'Droid Sans', 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
  color: var(--text-primary);
  background-color: var(--bg-color);
  height: 100%;
}

/* 容器样式 */
.container {
  padding: 20rpx;
  box-sizing: border-box;
}

/* 卡片样式 */
.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 20rpx;
}

/* 按钮样式 */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  transition: all 0.3s ease;
}

.btn-primary {
  background: linear-gradient(135deg, #07c160, #06ad56);
  color: #ffffff;
}

.btn-primary:active {
  opacity: 0.8;
}

.btn-secondary {
  background: #f5f5f5;
  color: var(--text-primary);
}

.btn-danger {
  background: var(--danger-color);
  color: #ffffff;
}

/* 文本样式 */
.text-primary {
  color: var(--primary-color);
}

.text-secondary {
  color: var(--text-secondary);
}

.text-tertiary {
  color: var(--text-tertiary);
}

.text-danger {
  color: var(--danger-color);
}

.text-warning {
  color: var(--warning-color);
}

.text-center {
  text-align: center;
}

.text-bold {
  font-weight: bold;
}

/* 布局样式 */
.flex {
  display: flex;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-wrap {
  flex-wrap: wrap;
}

.flex-1 {
  flex: 1;
}

/* 间距样式 */
.mt-10 { margin-top: 10rpx; }
.mt-20 { margin-top: 20rpx; }
.mt-30 { margin-top: 30rpx; }

.mb-10 { margin-bottom: 10rpx; }
.mb-20 { margin-bottom: 20rpx; }
.mb-30 { margin-bottom: 30rpx; }

.ml-10 { margin-left: 10rpx; }
.ml-20 { margin-left: 20rpx; }

.mr-10 { margin-right: 10rpx; }
.mr-20 { margin-right: 20rpx; }

.p-20 { padding: 20rpx; }
.p-30 { padding: 30rpx; }

/* 分割线 */
.divider {
  height: 1rpx;
  background-color: var(--border-color);
  margin: 20rpx 0;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-tertiary);
}

/* 加载状态 */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.loading-text {
  margin-left: 20rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* 标签样式 */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.tag-primary {
  background: rgba(7, 193, 96, 0.1);
  color: var(--primary-color);
}

.tag-warning {
  background: rgba(255, 195, 0, 0.1);
  color: var(--warning-color);
}

.tag-danger {
  background: rgba(250, 81, 81, 0.1);
  color: var(--danger-color);
}

/* 输入框样式 */
.input {
  height: 88rpx;
  padding: 0 30rpx;
  border: 1rpx solid var(--border-color);
  border-radius: 44rpx;
  font-size: 28rpx;
  background: #ffffff;
}

.input:focus {
  border-color: var(--primary-color);
}

/* 列表样式 */
.list-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background: #ffffff;
  border-bottom: 1rpx solid var(--border-color);
}

.list-item:last-child {
  border-bottom: none;
}

.list-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  margin-right: 20rpx;
}

.list-content {
  flex: 1;
}

.list-title {
  font-size: 30rpx;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.list-desc {
  font-size: 26rpx;
  color: var(--text-tertiary);
}

.list-arrow {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.3;
}
