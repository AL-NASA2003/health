.container {
  padding: 20rpx;
  min-height: 100vh;
  background-color: #f5f5f5;
}

.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 50vh;
}

.recipe-detail {
  background-color: #fff;
  border-radius: 10rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.recipe-header {
  margin-bottom: 20rpx;
}

.recipe-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.recipe-meta {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.recipe-category {
  font-size: 28rpx;
  color: #4CAF50;
  background-color: #f0f9ff;
  padding: 5rpx 15rpx;
  border-radius: 5rpx;
}

.recipe-calories {
  font-size: 28rpx;
  color: #666;
}

.recipe-image {
  width: 100%;
  height: 400rpx;
  border-radius: 10rpx;
  object-fit: cover;
}

/* 标签切换 */
.tab-container {
  display: flex;
  border-bottom: 1rpx solid #eee;
  margin-bottom: 20rpx;
}

.tab-item {
  flex: 1;
  padding: 20rpx;
  text-align: center;
  font-size: 32rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #4CAF50;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 20%;
  width: 60%;
  height: 4rpx;
  background-color: #4CAF50;
}

/* 制作步骤 */
.steps-container {
  margin-bottom: 20rpx;
}

.step-item {
  display: flex;
  margin-bottom: 20rpx;
}

.step-number {
  width: 50rpx;
  height: 50rpx;
  background-color: #4CAF50;
  color: #fff;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 28rpx;
  font-weight: bold;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.step-content {
  flex: 1;
}

.step-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
}

/* 视频教程 */
.video-container {
  margin-bottom: 20rpx;
}

.video-wrapper {
  width: 100%;
  height: 400rpx;
  background-color: #000;
  border-radius: 10rpx;
  overflow: hidden;
}

.video {
  width: 100%;
  height: 100%;
}

.no-video {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 200rpx;
  background-color: #f5f5f5;
  border-radius: 10rpx;
  color: #999;
  font-size: 28rpx;
}

/* 营养成分 */
.nutrition-container {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
  display: block;
}

.nutrition-list {
  display: flex;
  justify-content: space-around;
  background-color: #f9f9f9;
  padding: 20rpx;
  border-radius: 10rpx;
}

.nutrition-item {
  text-align: center;
}

.nutrition-label {
  display: block;
  font-size: 24rpx;
  color: #666;
  margin-bottom: 5rpx;
}

.nutrition-value {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

/* 操作按钮 */
.action-container {
  margin-top: 20rpx;
}

.action-btn {
  width: 100%;
  padding: 20rpx;
  background-color: #4CAF50;
  color: #fff;
  font-size: 32rpx;
  border-radius: 10rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 10rpx;
}

.action-icon {
  width: 32rpx;
  height: 32rpx;
}
