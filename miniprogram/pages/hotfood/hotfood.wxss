/* 操作栏 */
.action-bar {
  display: flex;
  gap: 10rpx;
  margin-bottom: 20rpx;
}

.refresh-btn, .crawl-btn {
  flex: 1;
  background-color: #4CAF50;
  color: #fff;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.crawl-btn {
  background-color: #2196F3;
}

/* 热点美食列表 */
.hotfood-list {
  margin-top: 20rpx;
}

.hotfood-item {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
  display: flex;
  align-items: center;
  gap: 20rpx;
  transition: all 0.3s ease;
}

.hotfood-item:active {
  transform: translateY(4rpx);
  box-shadow: 0 1rpx 5rpx rgba(0,0,0,0.03);
  padding-left: 25rpx;
  padding-right: 25rpx;
}

/* 排名 */
.rank-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100rpx;
}

.rank-num {
  width: 60rpx;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  background-color: #f0f0f0;
  color: #666;
  border-radius: 50%;
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.top-rank {
  background-color: #FF5722;
  color: #fff;
}

.hot-score {
  font-size: 22rpx;
  color: #999;
}

/* 美食信息 */
.food-info {
  flex: 1;
}

.food-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.ingre-list {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  margin-bottom: 10rpx;
}

.label {
  color: #999;
}

.crawl-time {
  font-size: 24rpx;
  color: #999;
}

/* 操作按钮 */
.action-btn {
  flex-shrink: 0;
}

/* 空数据提示 */
.empty {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* 加载中 */
.loading {
  text-align: center;
  padding: 50rpx 0;
  color: #666;
  font-size: 28rpx;
}

/* 骨架屏样式 */
.skeleton-container {
  margin-top: 20rpx;
}

.skeleton-item {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.skeleton-rank {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100rpx;
}

.skeleton-rank-num {
  width: 60rpx;
  height: 60rpx;
  background-color: #f0f0f0;
  border-radius: 50%;
  margin-bottom: 10rpx;
  animation: pulse 1.5s infinite;
}

.skeleton-hot-score {
  width: 80rpx;
  height: 24rpx;
  background-color: #f0f0f0;
  border-radius: 4rpx;
  animation: pulse 1.5s infinite;
}

.skeleton-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.skeleton-title {
  width: 80%;
  height: 32rpx;
  background-color: #f0f0f0;
  border-radius: 4rpx;
  animation: pulse 1.5s infinite;
}

.skeleton-desc {
  width: 100%;
  height: 26rpx;
  background-color: #f0f0f0;
  border-radius: 4rpx;
  animation: pulse 1.5s infinite;
}

.skeleton-time {
  width: 60%;
  height: 24rpx;
  background-color: #f0f0f0;
  border-radius: 4rpx;
  animation: pulse 1.5s infinite;
}

.skeleton-btn {
  width: 120rpx;
  height: 50rpx;
  background-color: #f0f0f0;
  border-radius: 8rpx;
  animation: pulse 1.5s infinite;
}

@keyframes pulse {
  0% {
    opacity: 0.6;
  }
  50% {
    opacity: 1;
  }
  100% {
    opacity: 0.6;
  }
}