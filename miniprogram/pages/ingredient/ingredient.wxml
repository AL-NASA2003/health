<view class="container">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <input 
      class="search-input" 
      placeholder="搜索食材名称" 
      value="{{searchKey}}"
      bindinput="onSearchInput"
      bindconfirm="searchIngredient"
    />
    <button class="search-btn" bindtap="searchIngredient">搜索</button>
  </view>

  <!-- 添加食材按钮 -->
  <view class="add-btn" bindtap="showAddDialog">+ 添加食材</view>

  <!-- 食材列表 -->
  <view wx:if="{{loading}}" class="loading">加载中...</view>
  <view wx:elif="{{ingredientList.length === 0}}" class="empty">
    {{searchKey ? '未找到相关食材' : '暂无食材数据'}}
    <view class="empty-tip" bindtap="showAddDialog">点击添加食材</view>
  </view>
  <view wx:else class="ingredient-list">
    <view class="ingredient-item" wx:for="{{ingredientList}}" wx:key="id">
      <!-- 食材基本信息 -->
      <view class="item-header">
        <view class="item-name">{{item.ingre_name}}</view>
        <view class="item-category">{{item.category}}</view>
      </view>

      <!-- 营养成分 -->
      <view class="nutrition-info">
        <view class="nutrition-item">
          <text class="label">热量</text>
          <text class="value">{{item.calorie}} 大卡/100g</text>
        </view>
        <view class="nutrition-item">
          <text class="label">蛋白质</text>
          <text class="value">{{item.protein}} g/100g</text>
        </view>
        <view class="nutrition-item">
          <text class="label">碳水</text>
          <text class="value">{{item.carb}} g/100g</text>
        </view>
        <view class="nutrition-item">
          <text class="label">脂肪</text>
          <text class="value">{{item.fat}} g/100g</text>
        </view>
      </view>

      <!-- 库存与保质期 -->
      <view class="stock-info" wx:if="{{item.stock > 0 || item.expire_date}}">
        <view wx:if="{{item.stock > 0}}" class="stock-item">
          库存：{{item.stock}} g
          <view class="stock-warning" wx:if="{{item.stock < 100}}">库存不足</view>
        </view>
        <view wx:if="{{item.expire_date}}" class="expire-item">
          保质期：{{item.expire_date}}
          <view class="expire-warning" wx:if="{{isExpired(item.expire_date)}}">已过期</view>
        </view>
      </view>

      <!-- 操作按钮 -->
      <view class="item-actions">
        <button size="mini" bindtap="editIngredient" data-item="{{item}}">编辑</button>
        <button size="mini" type="warn" bindtap="deleteIngredient" data-id="{{item.id}}">删除</button>
      </view>
    </view>
  </view>

  <!-- 添加/编辑食材弹窗 -->
  <view wx:if="{{showDialog}}" class="dialog-mask">
    <view class="dialog-container">
      <view class="dialog-title">{{isEdit ? '编辑食材' : '添加食材'}}</view>
      
      <view class="form-item">
        <label class="form-label">食材名称 *</label>
        <input 
          class="form-input" 
          placeholder="请输入食材名称" 
          value="{{formData.ingre_name}}"
          bindinput="onFormInput"
          data-key="ingre_name"
        />
      </view>

      <view class="form-item">
        <label class="form-label">食材分类</label>
        <picker mode="selector" range="{{categories}}" value="{{formData.categoryIndex}}" bindchange="onCategoryChange">
          <view class="form-input">
            {{categories[formData.categoryIndex]}}
          </view>
        </picker>
      </view>

      <view class="form-grid">
        <view class="form-item form-item-small">
          <label class="form-label">热量 *</label>
          <input 
            class="form-input" 
            type="number" 
            placeholder="大卡/100g" 
            value="{{formData.calorie}}"
            bindinput="onFormInput"
            data-key="calorie"
          />
        </view>
        <view class="form-item form-item-small">
          <label class="form-label">蛋白质 *</label>
          <input 
            class="form-input" 
            type="number" 
            placeholder="g/100g" 
            value="{{formData.protein}}"
            bindinput="onFormInput"
            data-key="protein"
          />
        </view>
      </view>

      <view class="form-grid">
        <view class="form-item form-item-small">
          <label class="form-label">碳水 *</label>
          <input 
            class="form-input" 
            type="number" 
            placeholder="g/100g" 
            value="{{formData.carb}}"
            bindinput="onFormInput"
            data-key="carb"
          />
        </view>
        <view class="form-item form-item-small">
          <label class="form-label">脂肪 *</label>
          <input 
            class="form-input" 
            type="number" 
            placeholder="g/100g" 
            value="{{formData.fat}}"
            bindinput="onFormInput"
            data-key="fat"
          />
        </view>
      </view>

      <view class="form-item">
        <label class="form-label">库存(g)</label>
        <input 
          class="form-input" 
          type="number" 
          placeholder="请输入库存数量" 
          value="{{formData.stock}}"
          bindinput="onFormInput"
          data-key="stock"
        />
      </view>

      <view class="form-item">
        <label class="form-label">保质期</label>
        <picker mode="date" value="{{formData.expire_date}}" bindchange="onDateChange">
          <view class="form-input">
            {{formData.expire_date || '选择日期'}}
          </view>
        </picker>
      </view>

      <view class="dialog-actions">
        <button size="mini" bindtap="hideDialog">取消</button>
        <button size="mini" type="primary" bindtap="submitForm">{{isEdit ? '保存' : '添加'}}</button>
      </view>
    </view>
  </view>
</view>