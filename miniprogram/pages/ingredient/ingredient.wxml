<view class="container">
  <!-- 页面标题 -->
  <view class="page-title">食材管理</view>
  
  <!-- 搜索栏 -->
  <view class="search-bar">
    <input 
      class="search-input" 
      placeholder="搜索食材名称" 
      value="{{searchKey}}"
      bindinput="onSearchInput"
      bindconfirm="searchIngredient"
    />
    <button class="search-btn" bindtap="searchIngredient">
      <text class="search-btn-text">搜索</text>
    </button>
  </view>

  <!-- 添加食材按钮 -->
  <view class="add-btn" bindtap="showAddDialog">
    <text class="add-btn-icon">+</text>
    <text class="add-btn-text">添加食材</text>
  </view>

  <!-- 食材列表 -->
  <view wx:if="{{loading}}" class="loading">
    <text class="loading-text">加载中...</text>
  </view>
  <view wx:elif="{{ingredientList.length === 0}}" class="empty">
    <view class="empty-icon">🥬</view>
    <text class="empty-text">{{searchKey ? '未找到相关食材' : '暂无食材数据'}}</text>
    <view class="empty-tip" bindtap="showAddDialog">
      <text class="empty-tip-text">点击添加食材</text>
    </view>
  </view>
  <view wx:else class="ingredient-list">
    <view class="ingredient-item" wx:for="{{ingredientList}}" wx:key="id">
      <!-- 食材基本信息 -->
      <view class="item-header">
        <view class="item-name">{{item.ingre_name}}</view>
        <view class="item-category">{{item.category}}</view>
      </view>

      <!-- 营养成分 -->
      <view class="nutrition-info">
        <view class="nutrition-item">
          <text class="nutrition-label">热量</text>
          <text class="nutrition-value">{{item.calorie}} 大卡/100g</text>
        </view>
        <view class="nutrition-item">
          <text class="nutrition-label">蛋白质</text>
          <text class="nutrition-value">{{item.protein}} g/100g</text>
        </view>
        <view class="nutrition-item">
          <text class="nutrition-label">碳水</text>
          <text class="nutrition-value">{{item.carb}} g/100g</text>
        </view>
        <view class="nutrition-item">
          <text class="nutrition-label">脂肪</text>
          <text class="nutrition-value">{{item.fat}} g/100g</text>
        </view>
      </view>

      <!-- 库存与保质期 -->
      <view class="stock-info" wx:if="{{item.stock > 0 || item.expire_date}}">
        <view wx:if="{{item.stock > 0}}" class="stock-item">
          <text class="stock-label">库存：</text>
          <text class="stock-value">{{item.stock}} g</text>
          <view class="stock-warning" wx:if="{{item.stock < 100}}">
            <text class="stock-warning-text">库存不足</text>
          </view>
        </view>
        <view wx:if="{{item.expire_date}}" class="expire-item">
          <text class="expire-label">保质期：</text>
          <text class="expire-value">{{item.expire_date}}</text>
          <view class="expire-warning" wx:if="{{isExpired(item.expire_date)}}">
            <text class="expire-warning-text">已过期</text>
          </view>
        </view>
      </view>

      <!-- 操作按钮 -->
      <view class="item-actions">
        <button class="action-btn edit-btn" bindtap="editIngredient" data-item="{{item}}">
          <text class="action-btn-text">编辑</text>
        </button>
        <button class="action-btn delete-btn" bindtap="deleteIngredient" data-id="{{item.id}}">
          <text class="action-btn-text">删除</text>
        </button>
      </view>
    </view>
  </view>

  <!-- 添加/编辑食材弹窗 -->
  <view wx:if="{{showDialog}}" class="dialog-mask">
    <view class="dialog-container">
      <view class="dialog-header">
        <view class="dialog-title">{{isEdit ? '编辑食材' : '添加食材'}}</view>
        <view class="dialog-close" bindtap="hideDialog">×</view>
      </view>
      
      <view class="dialog-body">
        <view class="form-item">
          <label class="form-label">食材名称 *</label>
          <input 
            class="form-input" 
            placeholder="请输入食材名称" 
            value="{{formData.ingre_name}}"
            bindinput="onFormInput"
            data-key="ingre_name"
          />
        </view>

        <view class="form-item">
          <label class="form-label">食材分类</label>
          <picker mode="selector" range="{{categories}}" value="{{formData.categoryIndex}}" bindchange="onCategoryChange">
            <view class="form-input picker-input">
              <text class="picker-text">{{categories[formData.categoryIndex]}}</text>
              <text class="picker-arrow">▼</text>
            </view>
          </picker>
        </view>

        <view class="form-grid">
          <view class="form-item form-item-small">
            <label class="form-label">热量 *</label>
            <input 
              class="form-input" 
              type="number" 
              placeholder="大卡/100g" 
              value="{{formData.calorie}}"
              bindinput="onFormInput"
              data-key="calorie"
            />
          </view>
          <view class="form-item form-item-small">
            <label class="form-label">蛋白质 *</label>
            <input 
              class="form-input" 
              type="number" 
              placeholder="g/100g" 
              value="{{formData.protein}}"
              bindinput="onFormInput"
              data-key="protein"
            />
          </view>
        </view>

        <view class="form-grid">
          <view class="form-item form-item-small">
            <label class="form-label">碳水 *</label>
            <input 
              class="form-input" 
              type="number" 
              placeholder="g/100g" 
              value="{{formData.carb}}"
              bindinput="onFormInput"
              data-key="carb"
            />
          </view>
          <view class="form-item form-item-small">
            <label class="form-label">脂肪 *</label>
            <input 
              class="form-input" 
              type="number" 
              placeholder="g/100g" 
              value="{{formData.fat}}"
              bindinput="onFormInput"
              data-key="fat"
            />
          </view>
        </view>

        <view class="form-item">
          <label class="form-label">库存(g)</label>
          <input 
            class="form-input" 
            type="number" 
            placeholder="请输入库存数量" 
            value="{{formData.stock}}"
            bindinput="onFormInput"
            data-key="stock"
          />
        </view>

        <view class="form-item">
          <label class="form-label">保质期</label>
          <picker mode="date" value="{{formData.expire_date}}" bindchange="onDateChange">
            <view class="form-input picker-input">
              <text class="picker-text">{{formData.expire_date || '选择日期'}}</text>
              <text class="picker-arrow">▼</text>
            </view>
          </picker>
        </view>
      </view>

      <view class="dialog-footer">
        <button class="dialog-btn cancel-btn" bindtap="hideDialog">
          <text class="dialog-btn-text">取消</text>
        </button>
        <button class="dialog-btn confirm-btn" bindtap="submitForm">
          <text class="dialog-btn-text">{{isEdit ? '保存' : '添加'}}</text>
        </button>
      </view>
    </view>
  </view>
</view>