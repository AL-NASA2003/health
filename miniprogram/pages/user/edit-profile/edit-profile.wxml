<view class="container">
  <!-- 页面标题 -->
  <view class="page-header">
    <text class="page-title">完善个人信息</text>
  </view>

  <!-- 头像上传区域 -->
  <view class="avatar-section">
    <button class="avatar-button" open-type="chooseAvatar" bind:chooseavatar="onChooseAvatar">
      <image class="avatar" src="{{userInfo.avatar || '../../images/default-avatar.png'}}"></image>
      <view class="avatar-upload-icon">
        <text>+</text>
      </view>
    </button>
    <text class="avatar-tip">点击选择头像</text>
  </view>

  <!-- 表单卡片 -->
  <view class="form-card">
    <!-- 昵称 -->
    <view class="input-group">
      <text class="input-label">昵称</text>
      <input 
        class="input" 
        placeholder="请输入昵称" 
        placeholder-class="input-placeholder"
        value="{{userInfo.nickname}}"
        bindinput="onNicknameInput"
      />
    </view>

    <!-- 身高体重 -->
    <view class="input-row">
      <view class="input-group half">
        <text class="input-label">身高 (cm)</text>
        <input 
          class="input" 
          placeholder="请输入身高" 
          placeholder-class="input-placeholder"
          value="{{userInfo.height}}"
          bindinput="onHeightInput"
          type="number"
        />
      </view>
      <view class="input-group half">
        <text class="input-label">体重 (kg)</text>
        <input 
          class="input" 
          placeholder="请输入体重" 
          placeholder-class="input-placeholder"
          value="{{userInfo.weight}}"
          bindinput="onWeightInput"
          type="number"
        />
      </view>
    </view>

    <!-- 腰围臀围 -->
    <view class="input-row">
      <view class="input-group half">
        <text class="input-label">腰围 (cm)</text>
        <input 
          class="input" 
          placeholder="请输入腰围" 
          placeholder-class="input-placeholder"
          value="{{userInfo.waist}}"
          bindinput="onWaistInput"
          type="number"
        />
      </view>
      <view class="input-group half">
        <text class="input-label">臀围 (cm)</text>
        <input 
          class="input" 
          placeholder="请输入臀围" 
          placeholder-class="input-placeholder"
          value="{{userInfo.hip}}"
          bindinput="onHipInput"
          type="number"
        />
      </view>
    </view>

    <!-- 年龄 -->
    <view class="input-group">
      <text class="input-label">年龄</text>
      <input 
        class="input" 
        placeholder="请输入年龄" 
        placeholder-class="input-placeholder"
        value="{{userInfo.age}}"
        bindinput="onAgeInput"
        type="number"
      />
    </view>

    <!-- 性别 -->
    <view class="input-group">
      <text class="input-label">性别</text>
      <view class="gender-selector">
        <view class="gender-item {{userInfo.gender === '男' ? 'active' : ''}}" bindtap="selectGender" data-gender="男">
          <text>男</text>
        </view>
        <view class="gender-item {{userInfo.gender === '女' ? 'active' : ''}}" bindtap="selectGender" data-gender="女">
          <text>女</text>
        </view>
      </view>
    </view>

    <!-- 健康目标 -->
    <view class="input-group">
      <text class="input-label">健康目标</text>
      <picker bindchange="onGoalChange" value="{{goalIndex}}" range="{{goalTypes}}">
        <view class="picker">
          {{goalTypes[goalIndex]}}
        </view>
      </picker>
    </view>

    <!-- 目标身材 -->
    <view class="input-group">
      <text class="input-label">目标身材</text>
      <picker bindchange="onBodyTypeChange" value="{{bodyTypeIndex}}" range="{{bodyTypes}}">
        <view class="picker">
          {{bodyTypes[bodyTypeIndex]}}
        </view>
      </picker>
    </view>

    <!-- 保存按钮 -->
    <button class="save-btn" bindtap="saveProfile">保存修改</button>
  </view>

  <!-- 健康饮食参考文献 -->
  <view class="references">
    <text class="references-title">健康饮食参考文献</text>
    <view class="reference-item">
      <text>1. Zeng Q, He Y.体重管理的未来：饮食模式与个性化营养[J].中华健康管理学杂志, 2023, 17(9): 645-648.</text>
    </view>
    <view class="reference-item">
      <text>2. 张行之. 不同人群的营养配餐策略探讨[J]. 现代食品, 2023, 29(24): 134-136</text>
    </view>
    <view class="reference-item">
      <text>3. 计算法编制食谱在平衡膳食营养配餐中的应用[J]. 现代食品, 2023, 29(11): 102-105+131</text>
    </view>
  </view>
</view>