.container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding: 20rpx;
}

.page-header {
  text-align: center;
  margin: 40rpx 0;
}

.page-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

/* 头像上传样式 */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin: 30rpx 0;
}

.avatar-button {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 2rpx solid #e0e0e0;
  margin-bottom: 15rpx;
  padding: 0;
  background-color: transparent;
  line-height: 1;
}

.avatar-button::after {
  border: none;
}

.avatar {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.avatar-upload-icon {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 40rpx;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-upload-icon text {
  color: #fff;
  font-size: 30rpx;
  font-weight: bold;
}

.avatar-tip {
  font-size: 24rpx;
  color: #666;
}

.form-card {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
  margin-bottom: 30rpx;
}

.input-group {
  margin-bottom: 30rpx;
}

.input-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 30rpx;
}

.input-group.half {
  width: 48%;
}

.input-label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.input {
  width: 100%;
  height: 80rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333;
  background-color: #fafafa;
}

.input-placeholder {
  color: #999;
}

.gender-selector {
  display: flex;
  gap: 20rpx;
}

.gender-item {
  flex: 1;
  height: 80rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #666;
  background-color: #fafafa;
}

.gender-item.active {
  border-color: #07c160;
  color: #07c160;
  background-color: #f0f9f4;
}

.picker {
  width: 100%;
  height: 80rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333;
  background-color: #fafafa;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.picker::after {
  content: '▼';
  font-size: 20rpx;
  color: #999;
}

.save-btn {
  width: 100%;
  height: 90rpx;
  background-color: #07c160;
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 12rpx;
  margin-top: 20rpx;
}

.references {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.references-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

.reference-item {
  margin-bottom: 15rpx;
}

.reference-item text {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
}

/* 响应式设计 */
@media (max-width: 750rpx) {
  .form-card {
    padding: 20rpx;
  }
  
  .input {
    height: 70rpx;
    font-size: 26rpx;
  }
  
  .gender-item {
    height: 70rpx;
    font-size: 26rpx;
  }
  
  .picker {
    height: 70rpx;
    font-size: 26rpx;
  }
  
  .save-btn {
    height: 80rpx;
    font-size: 30rpx;
  }
  
  .references {
    padding: 20rpx;
  }
  
  .references-title {
    font-size: 28rpx;
  }
  
  .reference-item text {
    font-size: 22rpx;
  }
}