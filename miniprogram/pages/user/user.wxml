<view class="container">
  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-container">
    <loading>加载中...</loading>
  </view>

  <!-- 用户信息 -->
  <view wx:else class="user-info">
    <view class="user-header">
      <image wx:if="{{userInfo.avatar}}" src="{{userInfo.avatar}}" class="user-avatar" />
      <image wx:else src="/images/default-avatar.png" class="user-avatar" />
      <view class="user-details">
        <text class="user-name">{{userInfo.nickname || '用户'}}</text>
        <text class="user-email">{{userInfo.email || '未设置邮箱'}}</text>
      </view>
    </view>

    <!-- 功能列表 -->
    <view class="function-list">
      <view class="function-item" bindtap="goToHealthSummary">
        <view class="function-icon">
          <text class="icon-emoji">📊</text>
        </view>
        <text class="function-text">健康汇总</text>
        <image src="/images/icon/arrow.png" class="arrow" />
      </view>
      <view class="function-item" bindtap="goToEditProfile">
        <view class="function-icon">
          <image src="/images/icon/profile.png" class="icon" />
        </view>
        <text class="function-text">完善个人信息</text>
        <image src="/images/icon/arrow.png" class="arrow" />
      </view>
      <view class="function-item" bindtap="goToHandbook">
        <view class="function-icon">
          <image src="/images/icon/handbook.png" class="icon" />
        </view>
        <text class="function-text">我的手账</text>
        <image src="/images/icon/arrow.png" class="arrow" />
      </view>
      <view class="function-item" bindtap="goToForum">
        <view class="function-icon">
          <image src="/images/icon/forum.png" class="icon" />
        </view>
        <text class="function-text">我的论坛</text>
        <image src="/images/icon/arrow.png" class="arrow" />
      </view>
      <view class="function-item" bindtap="goToCollection">
        <view class="function-icon">
          <image src="/images/icon/collect.png" class="icon" />
        </view>
        <text class="function-text">我的收藏</text>
        <image src="/images/icon/arrow.png" class="arrow" />
      </view>
      <view class="function-item" bindtap="goToLike">
        <view class="function-icon">
          <image src="/images/icon/like.png" class="icon" />
        </view>
        <text class="function-text">我的点赞</text>
        <image src="/images/icon/arrow.png" class="arrow" />
      </view>
    </view>

    <!-- 退出登录按钮 -->
    <button bindtap="logout" class="logout-btn">退出登录</button>
  </view>
</view>
