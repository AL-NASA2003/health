.container {
  padding: 20rpx;
  min-height: 100vh;
  background-color: #f5f5f5;
}

.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 50vh;
}

.user-info {
  background-color: #fff;
  border-radius: 10rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.user-header {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eee;
  margin-bottom: 20rpx;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.user-details {
  flex: 1;
}

.user-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.user-email {
  font-size: 28rpx;
  color: #666;
}

.function-list {
  margin-bottom: 30rpx;
}

.function-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.function-icon {
  width: 50rpx;
  height: 50rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-right: 20rpx;
}

.icon {
  width: 36rpx;
  height: 36rpx;
}

.icon-emoji {
  font-size: 40rpx;
  line-height: 1;
}

.function-text {
  flex: 1;
  font-size: 32rpx;
  color: #333;
}

.arrow {
  width: 24rpx;
  height: 24rpx;
  margin-left: 10rpx;
}

.logout-btn {
  width: 100%;
  padding: 20rpx;
  background-color: #ff4757;
  color: #fff;
  font-size: 32rpx;
  border-radius: 10rpx;
  margin-top: 20rpx;
}
