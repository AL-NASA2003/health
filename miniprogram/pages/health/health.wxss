.health-container {
  padding: 20rpx;
  min-height: 100vh;
  background-color: #f5f7fa;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.input-section,
.result-section,
.tips-section,
.history-section {
  background-color: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.form-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.form-item {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.form-label {
  font-size: 26rpx;
  color: #666;
}

.form-input {
  padding: 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 10rpx;
  font-size: 28rpx;
}

.form-picker {
  padding: 20rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 10rpx;
  font-size: 28rpx;
  color: #333;
  display: flex;
  flex-direction: column;
  gap: 5rpx;
}

.activity-item {
  margin-bottom: 30rpx;
}

.activity-desc {
  font-size: 22rpx;
  color: #999;
}

.calculate-btn {
  width: 100%;
  height: 90rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 10rpx;
  font-size: 30rpx;
  font-weight: bold;
}

.result-card {
  text-align: center;
}

.result-header {
  margin-bottom: 40rpx;
}

.result-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.bmi-section {
  margin-bottom: 40rpx;
}

.bmi-value {
  font-size: 100rpx;
  font-weight: bold;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  line-height: 1.2;
}

.bmi-label {
  font-size: 26rpx;
  color: #666;
  margin-top: 10rpx;
  display: block;
}

.bmi-status {
  display: inline-block;
  padding: 10rpx 30rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: bold;
  margin-top: 20rpx;
}

.bmi-status.thin {
  background-color: #e3f2fd;
  color: #1976d2;
}

.bmi-status.normal {
  background-color: #e8f5e9;
  color: #388e3c;
}

.bmi-status.overweight {
  background-color: #fff3e0;
  color: #f57c00;
}

.bmi-status.obese {
  background-color: #ffebee;
  color: #d32f2f;
}

.bmi-scale {
  margin-bottom: 40rpx;
}

.scale-bar {
  height: 20rpx;
  background: linear-gradient(90deg, #e3f2fd 0%, #e8f5e9 25%, #e8f5e9 50%, #fff3e0 75%, #ffebee 100%);
  border-radius: 10rpx;
  position: relative;
  margin-bottom: 15rpx;
}

.scale-fill {
  position: absolute;
  top: -5rpx;
  width: 20rpx;
  height: 30rpx;
  background-color: #333;
  border-radius: 50%;
  transform: translateX(-50%);
  left: 0%;
}

.scale-labels {
  display: flex;
  justify-content: space-between;
  font-size: 22rpx;
  color: #666;
}

.metrics-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.metric-item {
  padding: 25rpx 15rpx;
  background-color: #f8f9fa;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.metric-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #667eea;
  margin-bottom: 8rpx;
}

.metric-label {
  font-size: 20rpx;
  color: #666;
  text-align: center;
}

.tips-content {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.tip-item {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  padding: 15rpx;
  background-color: #f8f9fa;
  border-radius: 10rpx;
  border-left: 4rpx solid #667eea;
}

.tips-content text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.empty-history {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}

.history-list {
  max-height: 400rpx;
  overflow-y: auto;
}

.history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.history-item:last-child {
  border-bottom: none;
}

.history-info {
  display: flex;
  flex-direction: column;
  gap: 5rpx;
}

.history-date {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.history-bmi {
  font-size: 22rpx;
  color: #666;
}

.history-status {
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  font-size: 20rpx;
  font-weight: bold;
}

.history-status.thin {
  background-color: #e3f2fd;
  color: #1976d2;
}

.history-status.normal {
  background-color: #e8f5e9;
  color: #388e3c;
}

.history-status.overweight {
  background-color: #fff3e0;
  color: #f57c00;
}

.history-status.obese {
  background-color: #ffebee;
  color: #d32f2f;
}
