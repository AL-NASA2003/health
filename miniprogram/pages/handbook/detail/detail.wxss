.container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding: 20rpx;
}

.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
  font-size: 32rpx;
  color: #666;
}

.handbook-detail {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.1);
}

.handbook-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  line-height: 1.4;
}

.handbook-info {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 24rpx;
}

.handbook-image {
  margin-bottom: 32rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.handbook-image image {
  width: 100%;
  height: 400rpx;
  object-fit: cover;
}

.handbook-content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  margin-bottom: 32rpx;
}

.handbook-actions {
  display: flex;
  justify-content: space-around;
  margin-bottom: 32rpx;
}

.action-btn {
  flex: 1;
  margin: 0 8rpx;
  padding: 16rpx;
  border: 2rpx solid #1989fa;
  background-color: #fff;
  color: #1989fa;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.action-btn.edit-btn {
  border-color: #52c41a;
  color: #52c41a;
}

.action-btn.delete-btn {
  border-color: #ff4d4f;
  color: #ff4d4f;
}

.btn-text {
  font-size: 24rpx;
}

.edit-dialog {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: flex-end;
  z-index: 999;
}

.dialog-content {
  background-color: #fff;
  border-top-left-radius: 16rpx;
  border-top-right-radius: 16rpx;
  width: 100%;
  max-height: 80vh;
  padding: 32rpx;
}

.dialog-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.dialog-header text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.close-btn {
  font-size: 40rpx;
  color: #999;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  font-size: 24rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.form-input {
  width: 100%;
  padding: 16rpx;
  border: 2rpx solid #f0f0f0;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.form-textarea {
  width: 100%;
  height: 200rpx;
  padding: 16rpx;
  border: 2rpx solid #f0f0f0;
  border-radius: 8rpx;
  font-size: 24rpx;
  resize: none;
}

.image-upload {
  margin-top: 16rpx;
}

.image-preview {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 16rpx;
  border-radius: 8rpx;
  overflow: hidden;
}

.image-preview image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.upload-btn {
  padding: 16rpx;
  border: 2rpx dashed #1989fa;
  background-color: #f0f9ff;
  color: #1989fa;
  border-radius: 8rpx;
  font-size: 24rpx;
  width: 100%;
}

.dialog-footer {
  display: flex;
  justify-content: space-between;
  margin-top: 32rpx;
}

.cancel-btn {
  flex: 1;
  margin: 0 8rpx;
  padding: 16rpx;
  border: 2rpx solid #999;
  background-color: #fff;
  color: #999;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.submit-btn {
  flex: 1;
  margin: 0 8rpx;
  padding: 16rpx;
  border: 2rpx solid #1989fa;
  background-color: #1989fa;
  color: #fff;
  border-radius: 8rpx;
  font-size: 24rpx;
}
