.container {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding: 20rpx;
}

.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
  font-size: 32rpx;
  color: #666;
}

.post-detail {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.1);
}

.post-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  line-height: 1.4;
}

.post-info {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 24rpx;
}

.post-content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  margin-bottom: 32rpx;
}

.post-image {
  margin-bottom: 32rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.post-image image {
  width: 100%;
  height: 400rpx;
  object-fit: cover;
}

.post-stats {
  display: flex;
  justify-content: space-around;
  padding: 24rpx 0;
  border-top: 2rpx solid #f0f0f0;
  border-bottom: 2rpx solid #f0f0f0;
  margin-bottom: 32rpx;
}

.stat-item {
  font-size: 24rpx;
  color: #666;
  text-align: center;
}

.post-actions {
  display: flex;
  justify-content: space-around;
  margin-bottom: 32rpx;
}

.action-btn {
  flex: 1;
  margin: 0 8rpx;
  padding: 16rpx;
  border: 2rpx solid #1989fa;
  background-color: #fff;
  color: #1989fa;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.action-btn.delete-btn {
  border-color: #ff4d4f;
  color: #ff4d4f;
}

.btn-text {
  font-size: 24rpx;
}

.comments-section {
  margin-top: 32rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
}

.comment-list {
  margin-bottom: 24rpx;
}

.comment-item {
  padding: 24rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
}

.comment-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.comment-author {
  font-size: 24rpx;
  font-weight: bold;
  color: #333;
}

.comment-time {
  font-size: 20rpx;
  color: #999;
}

.comment-content {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
}

.no-comments {
  text-align: center;
  padding: 48rpx 0;
  font-size: 24rpx;
  color: #999;
}

.comment-dialog {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: flex-end;
  z-index: 999;
}

.dialog-content {
  background-color: #fff;
  border-top-left-radius: 16rpx;
  border-top-right-radius: 16rpx;
  width: 100%;
  max-height: 80vh;
  padding: 32rpx;
}

.dialog-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.dialog-header text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.close-btn {
  font-size: 40rpx;
  color: #999;
}

.comment-input {
  width: 100%;
  height: 200rpx;
  border: 2rpx solid #f0f0f0;
  border-radius: 8rpx;
  padding: 16rpx;
  font-size: 24rpx;
  margin-bottom: 24rpx;
  resize: none;
}

.dialog-footer {
  display: flex;
  justify-content: space-between;
}

.cancel-btn {
  flex: 1;
  margin: 0 8rpx;
  padding: 16rpx;
  border: 2rpx solid #999;
  background-color: #fff;
  color: #999;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.submit-btn {
  flex: 1;
  margin: 0 8rpx;
  padding: 16rpx;
  border: 2rpx solid #1989fa;
  background-color: #1989fa;
  color: #fff;
  border-radius: 8rpx;
  font-size: 24rpx;
}
