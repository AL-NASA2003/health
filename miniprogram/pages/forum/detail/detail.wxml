<view class="container">
  <view wx:if="{{loading}}" class="loading">
    <text>加载中...</text>
  </view>
  
  <view wx:else class="post-detail">
    <!-- 帖子标题 -->
    <view class="post-title">
      <text>{{postDetail.title}}</text>
    </view>
    
    <!-- 帖子信息 -->
    <view class="post-info">
      <text class="author">作者：{{postDetail.user_name || '未知'}}</text>
      <text class="time">{{postDetail.create_time || ''}}</text>
    </view>
    
    <!-- 帖子内容 -->
    <view class="post-content">
      <text>{{postDetail.content}}</text>
    </view>
    
    <!-- 帖子图片 -->
    <view wx:if="{{postDetail.image}}" class="post-image">
      <image src="{{postDetail.image}}" mode="aspectFit"></image>
    </view>
    
    <!-- 帖子统计 -->
    <view class="post-stats">
      <view class="stat-item">
        <text>浏览 {{postDetail.views || 0}}</text>
      </view>
      <view class="stat-item">
        <text>评论 {{postDetail.comments || 0}}</text>
      </view>
      <view class="stat-item">
        <text>点赞 {{postDetail.likes || 0}}</text>
      </view>
    </view>
    
    <!-- 操作按钮 -->
    <view class="post-actions">
      <button bindtap="likePost" class="action-btn" data-liked="{{postDetail.is_liked}}">
        <text class="btn-text">{{postDetail.is_liked ? '取消点赞' : '点赞'}}</text>
      </button>
      <button bindtap="collectPost" class="action-btn" data-collected="{{postDetail.is_collected}}">
        <text class="btn-text">{{postDetail.is_collected ? '取消收藏' : '收藏'}}</text>
      </button>
      <button bindtap="showCommentDialog" class="action-btn">
        <text class="btn-text">评论</text>
      </button>
      <button bindtap="deletePost" class="action-btn delete-btn">
        <text class="btn-text">删除</text>
      </button>
    </view>
    
    <!-- 评论列表 -->
    <view class="comments-section">
      <text class="section-title">评论</text>
      <view wx:if="{{postDetail.comments_list && postDetail.comments_list.length > 0}}" class="comment-list">
        <view wx:for="{{postDetail.comments_list}}" wx:key="{{item.id}}" class="comment-item">
          <view class="comment-header">
            <text class="comment-author">{{item.user_name || '匿名'}}</text>
            <text class="comment-time">{{item.create_time || ''}}</text>
          </view>
          <view class="comment-content">
            <text>{{item.content}}</text>
          </view>
        </view>
      </view>
      <view wx:else class="no-comments">
        <text>暂无评论，快来抢沙发吧！</text>
      </view>
    </view>
  </view>
  
  <!-- 评论弹窗 -->
  <view wx:if="{{showCommentDialog}}" class="comment-dialog">
    <view class="dialog-content">
      <view class="dialog-header">
        <text>发表评论</text>
        <text bindtap="hideCommentDialog" class="close-btn">×</text>
      </view>
      <textarea 
        bindinput="onCommentInput" 
        value="{{commentContent}}" 
        placeholder="请输入评论内容..." 
        class="comment-input"
      ></textarea>
      <view class="dialog-footer">
        <button bindtap="hideCommentDialog" class="cancel-btn">取消</button>
        <button bindtap="submitComment" class="submit-btn">提交</button>
      </view>
    </view>
  </view>
</view>
