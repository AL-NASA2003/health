/* 食谱推荐页面样式 */
.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 营养需求信息 */
.nutrition-info {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.nutrition-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
  color: #333;
}

.nutrition-content {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.nutrition-item {
  display: flex;
  align-items: center;
  background-color: #f0f9ff;
  padding: 12rpx 20rpx;
  border-radius: 8rpx;
  flex: 1;
  min-width: 150rpx;
}

.nutrition-label {
  font-size: 24rpx;
  color: #666;
  margin-right: 8rpx;
}

.nutrition-value {
  font-size: 24rpx;
  font-weight: bold;
  color: #07c160;
}

/* 筛选器 */
.filter-container {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.filter-btn {
  background-color: #fff;
  padding: 16rpx 24rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #333;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.arrow {
  margin-left: 8rpx;
  font-size: 20rpx;
  color: #999;
}

.recommend-btn {
  background-color: #07c160;
  color: #fff;
  border: none;
  border-radius: 8rpx;
  padding: 16rpx 32rpx;
  font-size: 28rpx;
  font-weight: bold;
}

/* 食谱列表 */
.recipe-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.recipe-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.loading, .empty {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* 食谱卡片 - 两栏布局 */
.recipe-card {
  width: calc(50% - 10rpx);
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
}

.recipe-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.08);
}

.recipe-image {
  width: 100%;
  height: 240rpx;
  overflow: hidden;
  background-color: #f0f0f0;
}

.recipe-image image {
  width: 100%;
  height: 100%;
}

.image-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #f0f0f0;
  color: #999;
  font-size: 24rpx;
}

.recipe-info {
  padding: 16rpx;
}

.recipe-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 12rpx;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* 营养统计 */
.nutrition-stats {
  display: flex;
  justify-content: space-between;
  gap: 8rpx;
}

.nutrition-stat {
  display: flex;
  align-items: center;
}

.stat-value {
  font-size: 22rpx;
  color: #666;
}

/* 食谱详情 */
.recipe-details {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.detail-item {
  display: flex;
  align-items: center;
  background-color: #f9f9f9;
  padding: 8rpx 16rpx;
  border-radius: 6rpx;
}

.detail-label {
  font-size: 22rpx;
  color: #666;
  margin-right: 8rpx;
}

.detail-value {
  font-size: 22rpx;
  color: #333;
}

/* 食材信息 */
.ingredients {
  margin-bottom: 20rpx;
  padding: 16rpx;
  background-color: #f9f9f9;
  border-radius: 8rpx;
}

.ingredients-label {
  font-size: 24rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
  display: block;
}

.ingredients-value {
  font-size: 22rpx;
  color: #666;
  line-height: 1.5;
}

/* 底部操作按钮 */
.recipe-actions-bottom {
  display: flex;
  gap: 16rpx;
}

.cook-step-btn, .detail-btn {
  flex: 1;
  padding: 16rpx;
  border: 1rpx solid #07c160;
  border-radius: 8rpx;
  font-size: 24rpx;
  text-align: center;
}

.cook-step-btn {
  background-color: #fff;
  color: #07c160;
}

.detail-btn {
  background-color: #07c160;
  color: #fff;
}

/* 烹饪步骤弹窗 */
.dialog-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.dialog-content {
  background-color: #fff;
  border-radius: 12rpx;
  width: 85%;
  max-height: 80vh;
  overflow-y: auto;
}

.dialog-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  border-bottom: 1rpx solid #eee;
}

.dialog-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
}

.close-btn {
  background: none;
  border: none;
  font-size: 40rpx;
  color: #999;
  line-height: 1;
  padding: 0;
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.dialog-body {
  padding: 20rpx;
}

.step-item {
  display: flex;
  margin-bottom: 20rpx;
  align-items: flex-start;
}

.step-number {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background-color: #07c160;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.step-text {
  flex: 1;
  font-size: 24rpx;
  color: #333;
  line-height: 1.5;
}

/* 响应式设计 */
@media (max-width: 750rpx) {
  .nutrition-content {
    flex-direction: column;
    gap: 12rpx;
  }
  
  .nutrition-item {
    min-width: auto;
  }
  
  .nutrition-stats {
    flex-wrap: wrap;
    gap: 12rpx;
  }
  
  .nutrition-stat {
    flex: 1;
    min-width: 100rpx;
  }
}