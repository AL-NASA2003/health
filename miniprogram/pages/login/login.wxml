<view class="container">
  <!-- Logo区域 -->
  <view class="logo-section">
    <view class="logo">
      <text style="font-size: 60rpx; color: #07c160;">🥗</text>
    </view>
    <text class="app-name">健康饮食助手</text>
    <text class="app-slogan">您的营养管家</text>
  </view>

  <!-- 登录方式切换 -->
  <view class="login-tabs">
    <view class="tab-item {{loginType === 'wechat' ? 'active' : ''}}" bindtap="switchLoginType" data-type="wechat">
      微信登录
    </view>
    <view class="tab-item {{loginType === 'phone' ? 'active' : ''}}" bindtap="switchLoginType" data-type="phone">
      手机号登录
    </view>
  </view>

  <!-- 登录卡片 -->
  <view class="login-card">
    <!-- 微信登录 -->
    <view wx:if="{{loginType === 'wechat'}}" class="wx-login-section">
      <button class="wx-login-btn" bindtap="wxLogin">
        微信一键登录
      </button>
      <text class="wx-login-tips">登录后可使用饮食记录、食谱推荐等功能</text>
    </view>

    <!-- 手机号登录 -->
    <view wx:elif="{{loginType === 'phone'}}" class="phone-login-section">
      <!-- 登录方式切换 -->
      <view class="phone-login-tabs">
        <view class="phone-tab-item {{phoneLoginType === 'sms' ? 'active' : ''}}" bindtap="switchPhoneLoginType" data-type="sms">
          验证码登录
        </view>
        <view class="phone-tab-item {{phoneLoginType === 'password' ? 'active' : ''}}" bindtap="switchPhoneLoginType" data-type="password">
          密码登录
        </view>
      </view>

      <!-- 手机号输入 -->
      <view class="input-group">
        <text class="input-label">手机号</text>
        <input 
          class="input" 
          placeholder="请输入手机号" 
          placeholder-class="input-placeholder"
          value="{{phone}}"
          bindinput="onPhoneInput"
          type="number"
        />
      </view>

      <!-- 验证码或密码输入 -->
      <view class="input-group">
        <text class="input-label">{{phoneLoginType === 'sms' ? '验证码' : '密码'}}</text>
        <view class="input-with-button">
          <input 
            class="input" 
            placeholder="{{phoneLoginType === 'sms' ? '请输入验证码' : '请输入密码'}}" 
            placeholder-class="input-placeholder"
            value="{{phoneLoginType === 'sms' ? smsCode : password}}"
            bindinput="onCodeInput"
            type="{{phoneLoginType === 'sms' ? 'number' : 'password'}}"
          />
          <button 
            wx:if="{{phoneLoginType === 'sms'}}" 
            class="send-code-btn"
            bindtap="sendSmsCode"
            disabled="{{countdown > 0}}"
          >
            {{countdown > 0 ? countdown + 's后重发' : '发送验证码'}}
          </button>
        </view>
      </view>

      <!-- 登录按钮 -->
      <button class="phone-login-btn" bindtap="phoneLogin">
        登录
      </button>

      <!-- 忘记密码 -->
      <view wx:if="{{phoneLoginType === 'password'}}" class="forgot-password">
        <text bindtap="forgotPassword">忘记密码？</text>
      </view>
    </view>
  </view>

  <!-- 注册入口 -->
  <view class="register-entry">
    <text>还没有账号？</text>
    <text class="register-link" bindtap="goToRegister">立即注册</text>
  </view>

  <!-- 开发模式提示 -->
  <view wx:if="{{isDev}}" style="margin-top: 40rpx; text-align: center;">
    <text style="font-size: 24rpx; color: #999;">开发模式：后端未连接时将使用模拟登录</text>
  </view>
</view>
