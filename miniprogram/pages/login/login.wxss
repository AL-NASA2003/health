.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* Logo区域 */
.logo-section {
  text-align: center;
  margin-bottom: 60rpx;
}

.logo {
  margin-bottom: 20rpx;
}

.app-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.app-slogan {
  font-size: 24rpx;
  color: #666;
}

/* 登录方式切换 */
.login-tabs {
  display: flex;
  width: 100%;
  max-width: 500rpx;
  margin-bottom: 30rpx;
  background-color: #f0f0f0;
  border-radius: 12rpx;
  overflow: hidden;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #07c160;
  background-color: white;
  font-weight: bold;
}

/* 登录卡片 */
.login-card {
  width: 100%;
  max-width: 500rpx;
  background-color: white;
  border-radius: 20rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 30rpx;
}

/* 微信登录 */
.wx-login-section {
  text-align: center;
}

/* 测试账号登录 */
.test-login-section {
  text-align: center;
}

.test-login-btn {
  width: 100%;
  background-color: #1890ff;
  color: white;
  font-size: 32rpx;
  font-weight: bold;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  margin-bottom: 20rpx;
}

.wx-login-btn {
  background-color: #07c160;
  color: white;
  font-size: 32rpx;
  font-weight: bold;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  margin-bottom: 20rpx;
}

.wx-login-tips {
  font-size: 20rpx;
  color: #999;
}

/* 手机号登录 */
.phone-login-section {
  width: 100%;
}

/* 手机号登录方式切换 */
.phone-login-tabs {
  display: flex;
  margin-bottom: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.phone-tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 24rpx;
  color: #666;
  position: relative;
}

.phone-tab-item.active {
  color: #07c160;
  font-weight: bold;
}

.phone-tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 20%;
  width: 60%;
  height: 4rpx;
  background-color: #07c160;
}

/* 输入组 */
.input-group {
  margin-bottom: 30rpx;
}

.input-label {
  display: block;
  font-size: 24rpx;
  color: #333;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #f0f0f0;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333;
  background-color: #f9f9f9;
}

.input-placeholder {
  color: #999;
}

.input-with-button {
  display: flex;
  align-items: center;
}

.input-with-button .input {
  flex: 1;
  margin-right: 16rpx;
}

.send-code-btn {
  height: 80rpx;
  padding: 0 24rpx;
  font-size: 24rpx;
  color: #07c160;
  border: 2rpx solid #07c160;
  background-color: white;
  border-radius: 12rpx;
  line-height: 80rpx;
}

/* 登录按钮 */
.phone-login-btn {
  width: 100%;
  background-color: #07c160;
  color: white;
  font-size: 32rpx;
  font-weight: bold;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  margin-bottom: 20rpx;
}

/* 忘记密码 */
.forgot-password {
  text-align: right;
}

.forgot-password text {
  font-size: 22rpx;
  color: #07c160;
}

/* 注册入口 */
.register-entry {
  text-align: center;
  font-size: 24rpx;
  color: #666;
}

.register-link {
  color: #07c160;
  margin-left: 8rpx;
  font-weight: 500;
}

/* 开发模式提示 */
.developer-tips {
  margin-top: 40rpx;
  text-align: center;
  font-size: 20rpx;
  color: #999;
}