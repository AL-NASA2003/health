.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 60rpx 40rpx;
}

/* 宣传海报 */
.poster-section {
  width: 100%;
  margin-bottom: 80rpx;
}

.poster {
  background: linear-gradient(135deg, #07c160, #07a855);
  border-radius: 24rpx;
  padding: 80rpx 40rpx;
  text-align: center;
  color: white;
  box-shadow: 0 10rpx 30rpx rgba(7, 193, 96, 0.3);
}

.poster-icon {
  font-size: 120rpx;
  display: block;
  margin-bottom: 30rpx;
}

.poster-title {
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.poster-slogan {
  font-size: 32rpx;
  margin-bottom: 20rpx;
  opacity: 0.9;
}

.poster-desc {
  font-size: 24rpx;
  opacity: 0.8;
  line-height: 1.5;
}

/* 功能介绍 */
.features-section {
  display: flex;
  justify-content: space-around;
  width: 100%;
  margin-bottom: 80rpx;
}

.feature-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.feature-icon {
  font-size: 60rpx;
  margin-bottom: 16rpx;
}

.feature-text {
  font-size: 24rpx;
  color: #666;
}

/* 登录注册按钮 */
.action-section {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-bottom: 60rpx;
}

.login-btn {
  background-color: #07c160;
  color: white;
  font-size: 32rpx;
  font-weight: bold;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.register-btn {
  background-color: white;
  color: #07c160;
  font-size: 32rpx;
  font-weight: bold;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #07c160;
}

/* 底部信息 */
.footer {
  text-align: center;
  padding-top: 20rpx;
}

.footer-text {
  font-size: 20rpx;
  color: #999;
}