<view class="container">
  <!-- 返回登录按钮 -->
  <view class="back-to-login">
    <text class="back-link" bindtap="goToLogin">← 返回登录</text>
  </view>

  <!-- Logo区域 -->
  <view class="logo-section">
    <view class="logo">
      <text style="font-size: 70rpx; color: #07c160;">🥗</text>
    </view>
    <text class="app-name">健康饮食助手</text>
    <text class="app-slogan">注册新账号</text>
  </view>

  <!-- 注册步骤指示器 -->
  <view class="step-indicator">
    <view class="step-item {{step === 1 ? 'active' : ''}}">
      <view class="step-circle">{{step === 1 ? '✓' : '1'}}</view>
      <text class="step-text">验证手机号</text>
    </view>
    <view class="step-line {{step >= 2 ? 'active' : ''}}"></view>
    <view class="step-item {{step === 2 ? 'active' : ''}}">
      <view class="step-circle">{{step === 2 ? '✓' : '2'}}</view>
      <text class="step-text">设置密码</text>
    </view>
    <view class="step-line {{step >= 3 ? 'active' : ''}}"></view>
    <view class="step-item {{step === 3 ? 'active' : ''}}">
      <view class="step-circle">{{step === 3 ? '✓' : '3'}}</view>
      <text class="step-text">完善信息</text>
    </view>
  </view>

  <!-- 注册表单 -->
  <view class="register-card">
    <!-- 第一步：验证手机号 -->
    <view wx:if="{{step === 1}}" class="step-content">
      <view class="input-group">
        <text class="input-label">手机号</text>
        <input 
          class="input" 
          placeholder="请输入手机号" 
          placeholder-class="input-placeholder"
          value="{{phone}}"
          bindinput="onPhoneInput"
          type="number"
        />
      </view>

      <view class="input-group">
        <text class="input-label">验证码</text>
        <view class="input-with-button">
          <input 
            class="input" 
            placeholder="请输入验证码" 
            placeholder-class="input-placeholder"
            value="{{smsCode}}"
            bindinput="onSmsCodeInput"
            type="number"
          />
          <button 
            class="send-code-btn"
            bindtap="sendSmsCode"
            disabled="{{countdown > 0}}"
          >
            {{countdown > 0 ? countdown + 's后重发' : '发送验证码'}}
          </button>
        </view>
      </view>

      <button class="next-btn" bindtap="nextStep">下一步</button>
    </view>

    <!-- 第二步：设置密码 -->
    <view wx:if="{{step === 2}}" class="step-content">
      <view class="input-group">
        <text class="input-label">设置密码</text>
        <input 
          class="input" 
          placeholder="请设置6-20位密码" 
          placeholder-class="input-placeholder"
          value="{{password}}"
          bindinput="onPasswordInput"
          type="password"
        />
      </view>

      <view class="input-group">
        <text class="input-label">确认密码</text>
        <input 
          class="input" 
          placeholder="请再次输入密码" 
          placeholder-class="input-placeholder"
          value="{{confirmPassword}}"
          bindinput="onConfirmPasswordInput"
          type="password"
        />
      </view>

      <button class="next-btn" bindtap="nextStep">下一步</button>
      <button class="prev-btn" bindtap="prevStep">上一步</button>
    </view>

    <!-- 第三步：完善信息 -->
    <view wx:if="{{step === 3}}" class="step-content">
      <view class="input-group">
        <text class="input-label">昵称</text>
        <input 
          class="input" 
          placeholder="请输入昵称" 
          placeholder-class="input-placeholder"
          value="{{nickname}}"
          bindinput="onNicknameInput"
        />
      </view>

      <view class="input-row">
        <view class="input-group half">
          <text class="input-label">身高 (cm)</text>
          <input 
            class="input" 
            placeholder="请输入身高" 
            placeholder-class="input-placeholder"
            value="{{height}}"
            bindinput="onHeightInput"
            type="number"
          />
        </view>
        <view class="input-group half">
          <text class="input-label">体重 (kg)</text>
          <input 
            class="input" 
            placeholder="请输入体重" 
            placeholder-class="input-placeholder"
            value="{{weight}}"
            bindinput="onWeightInput"
            type="number"
          />
        </view>
      </view>

      <view class="input-group">
        <text class="input-label">年龄</text>
        <input 
          class="input" 
          placeholder="请输入年龄" 
          placeholder-class="input-placeholder"
          value="{{age}}"
          bindinput="onAgeInput"
          type="number"
        />
      </view>

      <view class="input-group">
        <text class="input-label">性别</text>
        <view class="gender-selector">
          <view class="gender-item {{gender === '男' ? 'active' : ''}}" bindtap="selectGender" data-gender="男">
            <text>男</text>
          </view>
          <view class="gender-item {{gender === '女' ? 'active' : ''}}" bindtap="selectGender" data-gender="女">
            <text>女</text>
          </view>
        </view>
      </view>

      <view class="input-group">
        <text class="input-label">健康目标</text>
        <picker bindchange="onGoalChange" value="{{goalIndex}}" range="{{goalTypes}}">
          <view class="picker">
            {{goalTypes[goalIndex]}}
          </view>
        </picker>
      </view>

      <button class="register-btn" bindtap="register">完成注册</button>
      <button class="prev-btn" bindtap="prevStep">上一步</button>
    </view>
  </view>

  <!-- 登录入口 -->
  <view class="login-entry">
    <text>已有账号？</text>
    <text class="login-link" bindtap="goToLogin">立即登录</text>
  </view>
</view>